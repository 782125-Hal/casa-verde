# Casa Verde — copiar a .env y completar valores
# cp .env.example .env

# Django
SECRET_KEY=cambia-esto-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Producción (ejemplo para casaverde.marhal.com.mx) ---
# Genera un SECRET_KEY nuevo con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# SECRET_KEY=pega-aqui-la-clave-generada
# DEBUG=False
# ALLOWED_HOSTS=casaverde.marhal.com.mx
# CSRF_TRUSTED_ORIGINS=https://casaverde.marhal.com.mx
# SECURE_SSL_REDIRECT=True

# --- Alertas por email ---
# Desarrollo (imprime en consola del servidor):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Casa Verde <alertas@casaverde.local>

# Producción Gmail / SendGrid / Amazon SES — descomentar y completar:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu@gmail.com
# EMAIL_HOST_PASSWORD=app-password-de-16-caracteres

# --- Alertas por Telegram (gratis) ---
# 1. @BotFather → /newbot → pegar token aquí
# 2. Tu Chat ID va en /alertas/configuracion/ (no en este archivo)
TELEGRAM_BOT_TOKEN=